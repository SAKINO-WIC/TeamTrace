# Frontend API base path（开发时走 Vite 代理，保持 /api）
VITE_API_BASE_URL=/api

# 前端运行模式：
# live   = 只走真实接口
# hybrid = 优先真实接口，失败时回退本地演示数据
# mock   = 只走本地演示数据
VITE_APP_RUNTIME=live

# 开发代理：把浏览器的 /api 转发到后端根地址（须与后端 server.port / SERVER_PORT 一致）
# 登录报 502 多半是此处与后端端口不一致
VITE_API_PROXY_TARGET=http://localhost:8082

# 本地请用 http://127.0.0.1:5173 或 http://localhost:5173 均可（后端 CORS 默认两者都允许）
# 若直连后端（VITE_API_BASE_URL=http://localhost:8082/api），Origin 须在后端 ALLOWED_ORIGINS 中

# 线上 Render 示例见 .env.production.example（须配置真实后端 URL + 后端 ALLOWED_ORIGINS 含前端域名）

# 路由模式：hash / history。线上若刷新出现 404，使用 hash。
# 未设置时：生产默认 hash，开发默认 history。
# VITE_ROUTER_MODE=hash
