# Sealos / DevBox 开发示例：
# 1) 复制为 .env.sealos
# 2) bash scripts/run-dev.sh 会优先加载本文件（无则 .env / .env.local）
# 3) DB_URL：后端与 MySQL 同在集群内 → 用内网 Service，例如 teamtracedemo2：
#    jdbc:mysql://teamtracedemo2-mysql.ns-p2qarozz.svc:3306/team_trace?...
#    后端在你本机 Mac、库在 Sealos → 必须在控制台开启「外网地址」，勿写 .svc（本机解析不到）
# 4) SERVER_PORT 与前端 VITE_API_PROXY_TARGET 一致（常见本机联调 8082）
# 5) JDBC 里含 & 时整段 URL 用单引号包起来，否则 bash source 会把 & 当后台，DB_URL 不生效
# 6) 远程库 + ddl-auto=update 时若启动报 Communications link failure / Connection is closed：
#    在 URL 末尾追加（仍放在单引号内）：&connectTimeout=60000&socketTimeout=0
#    socketTimeout=0 表示读超时无限，仅建议开发联调；生产请用有限值或 Flyway 离线迁库。
# 7) 表结构已与实体一致、不想再自动改表时，可加一行：SPRING_JPA_HIBERNATE_DDL_AUTO=validate

DB_URL='jdbc:mysql://your-mysql-service.your-namespace.svc:3306/team_trace?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&connectTimeout=60000&socketTimeout=0'
DB_USERNAME=root
DB_PASSWORD=replace_with_real_password
SERVER_PORT=8082
TEAMTRACE_REQUIRE_HTTPS_FOR_AUTH=true
JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_EXPIRATION_SECONDS=604800

# 默认管理员（推荐邮箱登录；启动时若不存在则自动创建）
# ADMIN_EMAIL=your_admin@qq.com
# ADMIN_PASSWORD=replace_with_real_admin_password
# ADMIN_NAME=系统管理员
# 可选：保留手机号便于旧脚本/测试账号兼容
# ADMIN_PHONE=replace_with_11_digit_admin_phone

# Render / Sealos 线上推荐 Resend（SMTP 465 在 Render Free 不可用）
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_api_key
# MAIL_FROM=TeamTrace <onboarding@resend.dev>
