# 通用回退模板：
# - Windows 本地开发优先使用 .env.local（可参考 .env.local.example）
# - Sealos / DevBox 开发优先使用 .env.sealos（可参考 .env.sealos.example）
# - 若你仍沿用 .env，本项目脚本也兼容，但建议按环境拆分，避免本地和云端配置互相覆盖
# Never commit the real env files.

DB_URL='jdbc:mysql://your-mysql-host:3306/team_trace?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true'
DB_USERNAME=root
DB_PASSWORD=replace_with_real_password
# 与 spring-boot 监听端口一致；本地一般 8082，Sealos / DevBox 可按平台分配端口填写
SERVER_PORT=8082
TEAMTRACE_REQUIRE_HTTPS_FOR_AUTH=true
JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_EXPIRATION_SECONDS=604800

# 默认管理员（推荐邮箱登录；启动时若不存在则自动创建）
# ADMIN_EMAIL=your_admin@qq.com
# ADMIN_PASSWORD=replace_with_real_admin_password
# ADMIN_NAME=系统管理员
# 可选：保留手机号便于旧脚本/测试账号兼容
# ADMIN_PHONE=replace_with_11_digit_admin_phone

# 可选：关闭子任务截止定时提醒 → 在 application.properties 或 JVM 增加
# teamtrace.scheduler.subtask-deadline-reminder.enabled=false

# 可选：关闭 HTTP 操作日志写入
# teamtrace.audit.http.enabled=false
