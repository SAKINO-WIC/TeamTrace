# 若数据库在 Sealos：请用 .env.sealos（见 .env.sealos.example），run-dev.sh 会优先加载它，不必用本文件。
#
# Windows / 本机直连非 Sealos 库时：
# 1) 复制为 .env.local
# 2) 使用 scripts/run-dev.ps1 或 bash scripts/run-dev.sh .env.local
#
# --- 可选：本机 Docker MySQL（无云库时）---
# bash scripts/start-local-db.sh 后把下面三行写入 .env.local：
# DB_URL='jdbc:mysql://127.0.0.1:3306/team_trace?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true'
# DB_USERNAME=root
# DB_PASSWORD=teamtrace_dev

DB_URL='jdbc:mysql://your-public-mysql-host:3306/team_trace?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true'
DB_USERNAME=root
DB_PASSWORD=replace_with_real_password
SERVER_PORT=8082
TEAMTRACE_REQUIRE_HTTPS_FOR_AUTH=true
JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_EXPIRATION_SECONDS=604800

# 默认管理员（推荐邮箱登录；启动时若不存在则自动创建）
# ADMIN_EMAIL=your_admin@qq.com
# ADMIN_PASSWORD=replace_with_real_admin_password
# ADMIN_NAME=系统管理员
# 可选：保留手机号便于旧脚本/测试账号兼容（与 ADMIN_EMAIL 可同时配置）
# ADMIN_PHONE=replace_with_11_digit_admin_phone

# ── 邮件发信（二选一）────────────────────────────────────────────
# Render Free 线上：用 Resend（见 docs/EMAIL_SETUP.md §A）
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your_api_key
# MAIL_FROM=TeamTrace <onboarding@resend.dev>

# 本地 Mac 开发：QQ SMTP（显式 run-dev.sh .env.local）
# EMAIL_PROVIDER=smtp
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=465
# MAIL_USERNAME=your_qq@qq.com
# MAIL_PASSWORD=your_smtp_auth_code
# MAIL_FROM=your_qq@qq.com

# 前端开发 CORS（逗号分隔）。Vite 常用 http://127.0.0.1:5173，须与浏览器地址栏一致
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
